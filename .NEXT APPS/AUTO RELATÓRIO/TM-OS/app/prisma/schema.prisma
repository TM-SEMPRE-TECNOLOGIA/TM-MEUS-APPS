// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id           String      @id @default(uuid())
  title        String
  clientName   String?
  address      String?
  status       String      @default("PENDING") // PENDING, IN_PROGRESS, FINISHED
  technicianId String?
  technician   Technician? @relation(fields: [technicianId], references: [id])
  items        OrderItem[]
  comments     Comment[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  area        String   // Ex: Área Externa, Área Interna
  environment String   // Ex: Jardim, Sala, Cozinha
  type        String   // VISTA_AMPLA, SERVICO, DETALHE
  description String?  // Texto da mensagem estilo WhatsApp para o serviço
  photoPath   String?  // Caminho local da foto para o gerador Python
  createdAt   DateTime @default(now())
}

model Comment {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  author    String
  text      String
  createdAt DateTime @default(now())
}

model Technician {
  id     String  @id @default(uuid())
  name   String
  phone  String  @unique
  orders Order[]
}
